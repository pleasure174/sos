            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"FullName\": \"Patient One\",\n  \"email\": \"patient1@example.com\",\n  \"phonenumber\": \"1234567890\",\n  \"password\": \"Password123!\",\n  \"location\": \"City\",\n  \"role\": \"patient\"\n}"
            },
